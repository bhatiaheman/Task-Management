# Copy to .env and set your local Postgres connection string.
# Example: postgresql://USER:PASSWORD@localhost:5432/mydb?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME?schema=public"

JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long!!"
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_DAYS="7"
PORT=4000
CLIENT_ORIGIN="http://localhost:3000"

# TypeORM query logging
DB_LOGGING="false"

# Apply pending migrations before starting the API (see server.ts).
# You can also run: npm run migration:run
